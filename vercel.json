{
    "outputDirectory": "public",
    "installCommand": "composer install && npm install",
    "buildCommand": "npm run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false"
    },
    "build": {
        "env": {
            "COMPOSER_PROCESS_TIMEOUT": "0",
            "NODE_VERSION": "22"
        }
    }
}
